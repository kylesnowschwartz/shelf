{
  "name": "shelf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic, keyless reading-recommendation engine (agent-driven; --json primary). Owns the reading-list data and exports it to consumer sites.",
  "bin": {
    "shelf": "./shelf.mjs"
  },
  "engines": {
    "node": ">=23.6"
  },
  "scripts": {
    "shelf": "node shelf.mjs",
    "enrich:books": "node shelf.mjs enrich",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
